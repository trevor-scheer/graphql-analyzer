{
  "name": "@graphql-analyzer/napi",
  "version": "0.0.1",
  "private": true,
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "name": "graphql-analyzer",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu"
      ]
    }
  },
  "scripts": {
    "build": "napi build --cargo-cwd ../../crates/napi --platform --release",
    "build:debug": "napi build --cargo-cwd ../../crates/napi --platform"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0"
  }
}
