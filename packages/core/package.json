{
  "name": "@graphql-analyzer/core",
  "version": "0.1.2",
  "description": "Rust-powered GraphQL analyzer, callable from Node.js",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/trevor-scheer/graphql-analyzer.git",
    "directory": "packages/core"
  },
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "main": "index.js",
  "types": "index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "napi build --manifest-path ../../crates/napi/Cargo.toml --output-dir . --platform --release",
    "build:debug": "napi build --manifest-path ../../crates/napi/Cargo.toml --output-dir . --platform"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0"
  },
  "optionalDependencies": {
    "@graphql-analyzer/core-darwin-arm64": "0.1.2",
    "@graphql-analyzer/core-darwin-x64": "0.1.2",
    "@graphql-analyzer/core-linux-arm64-gnu": "0.1.2",
    "@graphql-analyzer/core-linux-x64-gnu": "0.1.2",
    "@graphql-analyzer/core-win32-x64-msvc": "0.1.2"
  },
  "napi": {
    "binaryName": "graphql-analyzer",
    "targets": [
      "x86_64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "aarch64-apple-darwin",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "engines": {
    "node": ">=18"
  }
}
