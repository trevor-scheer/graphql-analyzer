{
  "name": "graphql-lsp",
  "description": "GraphQL LSP powered by graphql-analyzer",
  "version": "0.1.0",
  "lspServers": {
    "graphql": {
      "command": "graphql-lsp",
      "extensionToLanguage": {
        ".graphql": "graphql",
        ".gql": "graphql",
        ".ts": "typescript",
        ".tsx": "typescriptreact",
        ".js": "javascript",
        ".jsx": "javascriptreact"
      }
    }
  }
}
