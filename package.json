{
  "name": "graphql-lsp-dev",
  "version": "0.0.0",
  "private": true,
  "description": "Development tools for graphql-lsp",
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "build:debug": "pnpm -r --if-present run build:debug",
    "compile": "pnpm -r --if-present run compile",
    "watch": "pnpm -r --if-present run watch",
    "typecheck": "tsc -b",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "package": "pnpm --filter graphql-analyzer run package",
    "test:unit": "pnpm -r --if-present run test:unit",
    "test:e2e": "pnpm -r --if-present run test:e2e",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check ."
  },
  "devDependencies": {
    "oxfmt": "^0.47.0",
    "oxlint": "^1.51.0",
    "typescript": "^5.0.0"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@vscode/vsce-sign",
      "esbuild",
      "keytar"
    ]
  }
}
