# pnpm settings тАФ see https://pnpm.io/npmrc
#
# `node-linker=hoisted` mirrors npm's flat node_modules layout. Keeps
# napi-rs addon resolution and ESLint plugin discovery behaviorally
# identical to the previous npm setup. Revisit later if/when we have
# coverage to confirm `isolated` (the default) works end-to-end.
node-linker=hoisted

# Auto-install peers and dedupe to match the resolution behavior we relied
# on under npm 11.
auto-install-peers=true
dedupe-peer-dependents=true
