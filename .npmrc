# pnpm settings — see https://pnpm.io/npmrc
#
# We use pnpm's default `node-linker=isolated` (symlinked `node_modules/.pnpm`
# virtual store) deliberately. The initial migration tried `node-linker=hoisted`
# as a paranoid mirror of npm's flat layout, but hoisted mode COPIES workspace
# packages into `node_modules/` rather than symlinking them — so rebuilding
# `packages/core/` (napi addon) didn't propagate to consumers, and the stale
# `.node` copy surfaced as real test failures (multi-project routing + parity
# rule list). The default isolated linker symlinks workspace packages, so dev
# iteration works the way you'd expect.

# Auto-install peers and dedupe to match resolution behavior consumers had
# under npm 11.
auto-install-peers=true
dedupe-peer-dependents=true

# pnpm 10 changed the default for `link-workspace-packages` to `false`, which
# means an exact-version dep like `"@graphql-analyzer/core": "0.1.2"` is
# resolved from the npm registry even though the workspace contains that
# package. Under npm, workspace packages always win for the resolver. Mirror
# that behavior so dev iteration on `packages/core/` propagates to consumers
# without needing `workspace:*` specifiers in every package.json.
link-workspace-packages=true
prefer-workspace-packages=true
